Options -Indexes

RewriteEngine On

# Fichier existant (JS, CSS, images...) -> servi tel quel
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Dossier qui contient vraiment un index.html (ex: /login/, /nfts/create/) -> laissé passer
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^ - [L]

# Tout le reste (routes gérées côté client par Angular, ex: /nfts, /users/42) -> index.html
RewriteRule ^ /index.html [L]
